# Copie este arquivo para .streamlit/secrets.toml (local) e preencha.
# No Streamlit Community Cloud, cole o conteúdo em: App > Settings > Secrets.
# NUNCA commite o secrets.toml real — ele está no .gitignore.

GROQ_API_KEY = "gsk_sua_chave_aqui"

# --- Envio automático do lead pra equipe (opcional) ---------------------------
# Quando o assistente fecha o RESUMO DO LEAD, o app envia pros destinos abaixo.
# Sem nada configurado, ele só mostra o card na conversa (nada quebra).

# Telegram (grátis, chega no celular na hora):
# 1. No Telegram, fale com @BotFather -> /newbot -> copie o token.
# 2. Fale com o seu bot novo (manda um "oi") e depois abra
#    https://api.telegram.org/bot<TOKEN>/getUpdates -> copie o "chat":{"id":...}
# TELEGRAM_BOT_TOKEN = "123456:ABC-token-do-botfather"
# TELEGRAM_CHAT_ID = "123456789"

# Webhook genérico (Google Sheets via Apps Script, Make, Zapier, CRM...):
# recebe POST JSON {"agente": "...", "momento": "...", "resumo": "..."}
# LEADS_WEBHOOK_URL = "https://exemplo.com/webhook"

# Direcionar por agente/cliente: acrescente o sufixo _<AGENTE> (maiúsculo).
# Ex.: leads do agente "aioti" pro Telegram da AIOTI, resto pro padrão:
# TELEGRAM_CHAT_ID_AIOTI = "987654321"
# LEADS_WEBHOOK_URL_CORRETOR_IMOVEIS = "https://exemplo.com/planilha-corretor"
